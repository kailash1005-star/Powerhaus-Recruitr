# ─────────────────────────────────────────────────────────────────────────────
# Recruitr backend environment template.
# Copy to `.env` (gitignored) and fill in real values. The matching demo runs on
# just MONGODB_URI + OPENAI_API_KEY — Pinecone is OPTIONAL (default uses Mongo).
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ────────────────────────────────────────────────────────────────
MONGODB_URI=
DATABASE_NAME=Job-Hunt
OPENAI_API_KEY=

# ── Matching engine (sensible defaults; override only if needed) ─────────────
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
EXTRACTION_MODEL=gpt-4o-mini
REASONING_MODEL=gpt-4o-mini

# Vector backend:
#   "mongo"    (default, no extra setup — best for the demo / test corpus, exact)
#   "atlas"    (PRODUCTION for thousands+ of CVs — native Atlas $vectorSearch ANN
#              + $search BM25 over the vectors already on the docs; no re-embed.
#              Requires an Atlas M10+ cluster. Indexes are created on startup;
#              tune ATLAS_* below.)
#   "pinecone" (external ANN — fill PINECONE_* below)
VECTOR_BACKEND=mongo
PINECONE_API_KEY=
PINECONE_INDEX=recruitr-cv
PINECONE_NAMESPACE=default
# Atlas backend (only if VECTOR_BACKEND=atlas)
ATLAS_VECTOR_INDEX=cv_vectors
ATLAS_SEARCH_INDEX=cv_lexical
ATLAS_NUM_CANDIDATES_MULT=20

# Matching tunables (defaults are fine for the demo)
MATCH_RETRIEVE_K=50
MATCH_REASON_TOP_N=10
MATCH_RETURN_TOP=5
MAX_UPLOAD_MB=10

# Outreach email — DRAFTING works with just OPENAI_API_KEY. To actually SEND,
# fill these (e.g. Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_USER=
# your address, SMTP_PASSWORD=a Gmail App Password). Leave blank = draft-only.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=Recruitr
OUTREACH_SENDER_NAME=The Talent Team

# ── Outreach CRM tracking (Smartlead sending + Cal.com meetings) ─────────────
# Powers Outreach → Leads / Candidates. ALL OPTIONAL — the CRM renders empty and
# /health reports "not configured" when blank. How it works:
#   • SMARTLEAD_API_KEY (+ a campaign id) lets the tool ENROLL contacts to send.
#   • Live open/reply/bounce/unsubscribe data arrives via Smartlead WEBHOOKS →
#     point Smartlead at:  https://<your-host>/api/v1/outreach/webhooks/smartlead
#   • Meetings arrive via Cal.com WEBHOOK (triggerEvent BOOKING_CREATED) →
#     point Cal.com at:    https://<your-host>/api/v1/outreach/webhooks/calcom
#   • The *_WEBHOOK_SECRET values turn ON signature verification (recommended in
#     prod). Leave blank for local testing and webhooks are accepted unsigned.
OUTREACH_PROVIDER=smartlead
OUTREACH_TENANT_ID=default
SMARTLEAD_API_KEY=
SMARTLEAD_BASE_URL=https://server.smartlead.ai/api/v1
SMARTLEAD_DEFAULT_CAMPAIGN_ID=
SMARTLEAD_WEBHOOK_SECRET=
CALCOM_API_KEY=
CALCOM_WEBHOOK_SECRET=

# ── Existing integrations (leave blank if unused) ───────────────────────────
FIRECRAWL_API_KEY=
APOLLO_API_KEY=
APOLLO_WEBHOOK_URL=
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
LINKEDIN_LI_AT=
LINKEDIN_JSESSIONID=
