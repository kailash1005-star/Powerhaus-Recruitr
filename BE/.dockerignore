# Keep the cloud image small + clean — never pack these in.
venv/
__pycache__/
*.pyc
*.pyo
.env
.git/
.gitignore
.vscode/
*.md

# Local-only helpers and artifacts (not needed in the cloud)
run.bat
run.ps1
run.sh
*.log
.linkedin_cookies/

# Tests and their tooling never ship in the production image
tests/
.pytest_cache/
pytest.ini
requirements-dev.txt

Dockerfile
.dockerignore
